# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Data Configuration
DATA_DIR=data
RAW_DATA_DIR=data/raw
PREPROCESSED_DATA_DIR=data/preprocessing
DATASET_SIZE=0.1  # 10% of the full dataset

# Model Configuration
MODEL_SAVE_DIR=models
BATCH_SIZE=32
LEARNING_RATE=0.001
NUM_EPOCHS=10
IMAGE_SIZE=224

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=protein_atlas_classification

# Docker Configuration
DOCKER_REGISTRY=your-registry
DOCKER_IMAGE_PREFIX=hpc-drug-discovery

# Infrastructure Configuration
CLUSTER_NAME=hpc-drug-discovery
INSTANCE_TYPE=hpc6a.48xlarge
MIN_NODES=1
MAX_NODES=2
SPOT_PRICE=0.5  # Maximum spot price in USD

# Cost Control
MAX_RUNTIME_HOURS=2
COST_BUDGET_CAD=20 